# ══════════════════════════════════════════════════════════════════════════════
#  .env.example — Plantilla de variables de entorno
#  Logistics Validation API
#
#  USO:
#    Desarrollo local → copiar como .env y ajustar valores si es necesario:
#      cp .env.example .env
#
#    CI (GitHub Actions) → el pipeline hace `cp .env.example .env` automáticamente.
#
#  IMPORTANTE:
#    - NUNCA commitear el .env real si contiene secretos.
#    - Este archivo (.env.example) SÍ se versiona; es la fuente de verdad
#      de las variables requeridas con valores seguros por defecto.
# ══════════════════════════════════════════════════════════════════════════════

# ── Metadatos de la aplicación ────────────────────────────────────────────────
APP_NAME="Logistics Validation API"
APP_VERSION="1.0.0"

# ── Servidor Uvicorn ──────────────────────────────────────────────────────────
# No modificar en Docker: el contenedor siempre escucha en 0.0.0.0:8000.
# El acceso externo se hace únicamente a través de Nginx (puerto 80).
HOST=0.0.0.0
PORT=8000

# ── Swagger UI / OpenAPI ──────────────────────────────────────────────────────
# true  → /docs y /redoc disponibles (recomendado para desarrollo y CI)
# false → desactivar en producción si Nginx no protege esas rutas
DOCS_ENABLED=true
